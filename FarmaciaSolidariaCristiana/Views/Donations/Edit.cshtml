@model FarmaciaSolidariaCristiana.Models.Donation
@{
    ViewData["Title"] = "Editar Donación";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-warning">
            <h4 class="mb-0">@ViewData["Title"]</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                
                <div class="form-group mb-3">
                    <label class="form-label">Tipo de Donación <span class="text-danger">*</span></label>
                    <div class="btn-group w-100" role="group">
                        <input type="radio" class="btn-check" name="donationType" id="medicineType" value="medicine" @(Model.MedicineId.HasValue ? "checked" : "")>
                        <label class="btn btn-outline-primary" for="medicineType">
                            <i class="bi bi-capsule"></i> Medicamento
                        </label>
                        
                        <input type="radio" class="btn-check" name="donationType" id="supplyType" value="supply" @(!Model.MedicineId.HasValue ? "checked" : "")>
                        <label class="btn btn-outline-info" for="supplyType">
                            <i class="bi bi-box-seam"></i> Insumo
                        </label>
                    </div>
                </div>

                <div class="form-group mb-3" id="medicineSelect" style="display: @(Model.MedicineId.HasValue ? "block" : "none");">
                    <label class="form-label">Medicamento</label>
                    <div class="input-group">
                        <input type="text" id="medicineSearch" class="form-control" placeholder="Buscar medicamento..." />
                    </div>
                    <input type="hidden" asp-for="MedicineId" id="selectedMedicineId" />
                    <div id="medicineResults" class="list-group mt-2"></div>
                    <div id="selectedMedicineDisplay" class="alert alert-info mt-2" style="display: none;">
                        <small id="selectedMedicineName"></small>
                    </div>
                    <span asp-validation-for="MedicineId" class="text-danger"></span>
                </div>

                <div class="form-group mb-3" id="supplySelect" style="display: @(!Model.MedicineId.HasValue ? "block" : "none");">
                    <label class="form-label">Insumo</label>
                    <div class="input-group">
                        <input type="text" id="supplySearch" class="form-control" placeholder="Buscar insumo..." />
                    </div>
                    <input type="hidden" asp-for="SupplyId" id="selectedSupplyId" />
                    <div id="supplyResults" class="list-group mt-2"></div>
                    <div id="selectedSupplyDisplay" class="alert alert-info mt-2" style="display: none;">
                        <small id="selectedSupplyName"></small>
                    </div>
                    <span asp-validation-for="SupplyId" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label asp-for="Quantity" class="form-label"></label>
                    <input asp-for="Quantity" class="form-control" type="number" min="1" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label asp-for="DonationDate" class="form-label"></label>
                    <input asp-for="DonationDate" class="form-control" type="date" />
                    <span asp-validation-for="DonationDate" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label asp-for="DonorNote" class="form-label"></label>
                    <textarea asp-for="DonorNote" class="form-control" rows="3" placeholder="Información del donante (opcional)"></textarea>
                </div>
                
                <div class="form-group mb-3">
                    <label asp-for="Comments" class="form-label"></label>
                    <textarea asp-for="Comments" class="form-control" rows="2"></textarea>
                </div>
                
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-warning">Guardar Cambios</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const medicineRadio = document.getElementById('medicineType');
            const supplyRadio = document.getElementById('supplyType');
            const medicineSelect = document.getElementById('medicineSelect');
            const supplySelect = document.getElementById('supplySelect');
            const medicineSearch = document.getElementById('medicineSearch');
            const supplySearch = document.getElementById('supplySearch');
            const medicineResults = document.getElementById('medicineResults');
            const supplyResults = document.getElementById('supplyResults');
            const selectedMedicineId = document.getElementById('selectedMedicineId');
            const selectedSupplyId = document.getElementById('selectedSupplyId');
            const selectedMedicineDisplay = document.getElementById('selectedMedicineDisplay');
            const selectedSupplyDisplay = document.getElementById('selectedSupplyDisplay');
            const selectedMedicineName = document.getElementById('selectedMedicineName');
            const selectedSupplyName = document.getElementById('selectedSupplyName');

            // Mostrar el nombre del medicamento/insumo si ya está seleccionado
            function displayCurrentSelection() {
                if (selectedMedicineId.value) {
                    medicineSearch.value = selectedMedicineName.textContent;
                    selectedMedicineDisplay.style.display = 'block';
                } else if (selectedSupplyId.value) {
                    supplySearch.value = selectedSupplyName.textContent;
                    selectedSupplyDisplay.style.display = 'block';
                }
            }

            // Búsqueda de medicamentos
            medicineSearch.addEventListener('input', async function() {
                const query = this.value.trim();
                
                if (query.length < 3) {
                    medicineResults.innerHTML = '';
                    return;
                }

                try {
                    const response = await fetch(`/Donations/SearchItems?query=${encodeURIComponent(query)}`);
                    const data = await response.json();
                    medicineResults.innerHTML = '';

                    const medicines = data.items.filter(item => item.type === 'medicine');
                    
                    if (medicines.length === 0) {
                        medicineResults.innerHTML = '<small class="text-muted p-2">No se encontraron medicamentos</small>';
                        return;
                    }

                    medicines.forEach(medicine => {
                        const button = document.createElement('button');
                        button.type = 'button';
                        button.className = 'list-group-item list-group-item-action';
                        button.innerHTML = `${medicine.name} <small class="text-muted">(${medicine.unit})</small>`;
                        button.addEventListener('click', function(e) {
                            e.preventDefault();
                            selectedMedicineId.value = medicine.id;
                            medicineSearch.value = medicine.name;
                            selectedMedicineName.textContent = medicine.name;
                            medicineResults.innerHTML = '';
                            selectedMedicineDisplay.style.display = 'block';
                        });
                        medicineResults.appendChild(button);
                    });
                } catch (error) {
                    console.error('Error:', error);
                }
            });

            // Búsqueda de insumos
            supplySearch.addEventListener('input', async function() {
                const query = this.value.trim();
                
                if (query.length < 3) {
                    supplyResults.innerHTML = '';
                    return;
                }

                try {
                    const response = await fetch(`/Donations/SearchItems?query=${encodeURIComponent(query)}`);
                    const data = await response.json();
                    supplyResults.innerHTML = '';

                    const supplies = data.items.filter(item => item.type === 'supply');
                    
                    if (supplies.length === 0) {
                        supplyResults.innerHTML = '<small class="text-muted p-2">No se encontraron insumos</small>';
                        return;
                    }

                    supplies.forEach(supply => {
                        const button = document.createElement('button');
                        button.type = 'button';
                        button.className = 'list-group-item list-group-item-action';
                        button.innerHTML = `${supply.name} <small class="text-muted">(${supply.unit})</small>`;
                        button.addEventListener('click', function(e) {
                            e.preventDefault();
                            selectedSupplyId.value = supply.id;
                            supplySearch.value = supply.name;
                            selectedSupplyName.textContent = supply.name;
                            supplyResults.innerHTML = '';
                            selectedSupplyDisplay.style.display = 'block';
                        });
                        supplyResults.appendChild(button);
                    });
                } catch (error) {
                    console.error('Error:', error);
                }
            });

            function toggleSelects() {
                if (medicineRadio.checked) {
                    medicineSelect.style.display = 'block';
                    supplySelect.style.display = 'none';
                    selectedSupplyId.value = '';
                } else {
                    medicineSelect.style.display = 'none';
                    supplySelect.style.display = 'block';
                    selectedMedicineId.value = '';
                }
            }

            medicineRadio.addEventListener('change', toggleSelects);
            supplyRadio.addEventListener('change', toggleSelects);

            toggleSelects();
            displayCurrentSelection();
        });
    </script>
}
