@model FarmaciaSolidariaCristiana.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Registro";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-4">
                    <i class="bi bi-person-plus-fill text-primary"></i> Crear Cuenta
                </h2>
                
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label">
                            <i class="bi bi-person"></i> @Html.DisplayNameFor(m => m.UserName)
                        </label>
                        <input asp-for="UserName" class="form-control" placeholder="Ingrese su nombre de usuario" autofocus />
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">
                            <i class="bi bi-envelope"></i> @Html.DisplayNameFor(m => m.Email)
                        </label>
                        <div class="input-group">
                            <input asp-for="Email" class="form-control" placeholder="correo@ejemplo.com" id="emailInput" />
                            <button type="button" class="btn btn-outline-primary" id="btnSendCode" onclick="sendVerificationCode()">
                                <i class="bi bi-send"></i> Enviar código
                            </button>
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                        <div id="emailCodeMessage" class="mt-1" style="display:none;"></div>
                    </div>

                    <div class="mb-3" id="verificationCodeGroup" style="display:none;">
                        <label asp-for="VerificationCode" class="form-label">
                            <i class="bi bi-shield-check"></i> @Html.DisplayNameFor(m => m.VerificationCode)
                        </label>
                        <input asp-for="VerificationCode" class="form-control text-center" 
                               placeholder="Ingrese el código de 6 dígitos" maxlength="6"
                               style="font-size: 1.2rem; letter-spacing: 5px;" />
                        <span asp-validation-for="VerificationCode" class="text-danger"></span>
                        <small class="form-text text-muted">
                            Revisa tu correo electrónico. El código expira en 10 minutos.
                        </small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">
                            <i class="bi bi-lock"></i> @Html.DisplayNameFor(m => m.Password)
                        </label>
                        <input asp-for="Password" class="form-control" placeholder="Mínimo 6 caracteres" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                        <small class="form-text text-muted">
                            Debe contener mayúsculas, minúsculas, números y caracteres especiales.
                        </small>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label">
                            <i class="bi bi-lock-fill"></i> @Html.DisplayNameFor(m => m.ConfirmPassword)
                        </label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Repita la contraseña" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-check-circle"></i> Registrarse
                        </button>
                        <a asp-action="Login" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Volver al inicio de sesión
                        </a>
                    </div>
                </form>

                <div class="mt-3 text-center">
                    <p class="text-muted small">
                        <i class="bi bi-info-circle"></i> Al registrarse, tendrás acceso de solo lectura al sistema.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        let codeSent = false;
        let cooldownTimer = null;

        async function sendVerificationCode() {
            const email = document.getElementById('emailInput').value.trim();
            const msgDiv = document.getElementById('emailCodeMessage');
            const btn = document.getElementById('btnSendCode');

            if (!email || !email.includes('@@') || !email.includes('.')) {
                msgDiv.style.display = 'block';
                msgDiv.className = 'mt-1 text-danger small';
                msgDiv.textContent = 'Ingrese un correo electrónico válido.';
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Enviando...';

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                const response = await fetch('@Url.Action("SendVerificationCode", "Account")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({ email: email })
                });
                const data = await response.json();

                msgDiv.style.display = 'block';
                if (data.success) {
                    msgDiv.className = 'mt-1 text-success small';
                    msgDiv.textContent = data.message;
                    document.getElementById('verificationCodeGroup').style.display = 'block';
                    codeSent = true;
                    startCooldown(60);
                } else {
                    msgDiv.className = 'mt-1 text-danger small';
                    msgDiv.textContent = data.message;
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-send"></i> Enviar código';
                }
            } catch (err) {
                msgDiv.style.display = 'block';
                msgDiv.className = 'mt-1 text-danger small';
                msgDiv.textContent = 'Error de conexión. Inténtelo de nuevo.';
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-send"></i> Enviar código';
            }
        }

        function startCooldown(seconds) {
            const btn = document.getElementById('btnSendCode');
            let remaining = seconds;
            btn.disabled = true;
            btn.textContent = `Reenviar (${remaining}s)`;
            cooldownTimer = setInterval(() => {
                remaining--;
                if (remaining <= 0) {
                    clearInterval(cooldownTimer);
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-arrow-repeat"></i> Reenviar código';
                } else {
                    btn.textContent = `Reenviar (${remaining}s)`;
                }
            }, 1000);
        }
    </script>
}
