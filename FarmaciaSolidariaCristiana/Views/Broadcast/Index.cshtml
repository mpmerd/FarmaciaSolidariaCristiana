@{
    ViewData["Title"] = "Notificación Masiva";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">
                        <i class="bi bi-megaphone"></i> Enviar Notificación Masiva
                    </h3>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <div class="alert alert-info mb-4">
                        <i class="bi bi-info-circle-fill"></i>
                        <strong>Usuarios registrados:</strong> @ViewBag.UserCount
                        <br>
                        <small class="text-muted">La notificación se enviará a todos los usuarios por los canales seleccionados.</small>
                    </div>

                    <form method="post" asp-action="Send" id="broadcastForm">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-3">
                            <label for="title" class="form-label">Título <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="title" name="title" 
                                   maxlength="150" required
                                   placeholder="Ej: Aviso importante, Horario especial, etc.">
                            <div class="form-text">Máximo 150 caracteres.</div>
                        </div>

                        <div class="mb-4">
                            <label for="message" class="form-label">Mensaje <span class="text-danger">*</span></label>
                            <textarea class="form-control" id="message" name="message" rows="6" 
                                      maxlength="2000" required
                                      placeholder="Escriba el mensaje que desea enviar a todos los usuarios..."></textarea>
                            <div class="form-text">
                                <span id="charCount">0</span>/2000 caracteres.
                            </div>
                        </div>

                        <div class="card bg-light mb-4">
                            <div class="card-body">
                                <h6 class="card-title mb-3">
                                    <i class="bi bi-send"></i> Canales de envío
                                </h6>
                                
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" id="sendEmail" name="sendEmail" value="true" checked>
                                    <label class="form-check-label" for="sendEmail">
                                        <i class="bi bi-envelope-fill text-primary"></i> <strong>Email</strong>
                                        <small class="text-muted d-block">Se enviará un correo a cada usuario registrado.</small>
                                    </label>
                                </div>
                                
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="sendNotification" name="sendNotification" value="true" checked>
                                    <label class="form-check-label" for="sendNotification">
                                        <i class="bi bi-bell-fill text-warning"></i> <strong>Notificación en la App</strong>
                                        <small class="text-muted d-block">Aparecerá como notificación en la aplicación móvil.</small>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg" id="btnSend">
                                <i class="bi bi-megaphone"></i> Enviar Notificación Masiva
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="mt-3 text-center">
                <a asp-controller="Turnos" asp-action="Dashboard" class="text-decoration-none">
                    <i class="bi bi-arrow-left"></i> Volver al Dashboard
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Contador de caracteres
        const messageField = document.getElementById('message');
        const charCount = document.getElementById('charCount');
        messageField.addEventListener('input', function() {
            charCount.textContent = this.value.length;
        });

        // Confirmación antes de enviar
        document.getElementById('broadcastForm').addEventListener('submit', function(e) {
            const sendEmail = document.getElementById('sendEmail').checked;
            const sendNotification = document.getElementById('sendNotification').checked;
            
            if (!sendEmail && !sendNotification) {
                e.preventDefault();
                alert('Debe seleccionar al menos un canal de envío.');
                return;
            }

            const channels = [];
            if (sendEmail) channels.push('email');
            if (sendNotification) channels.push('notificación en app');
            
            const msg = `¿Está seguro de enviar esta notificación masiva a TODOS los usuarios por ${channels.join(' y ')}?\n\nEsta acción no se puede deshacer.`;
            
            if (!confirm(msg)) {
                e.preventDefault();
                return;
            }

            // Deshabilitar botón para evitar doble envío
            const btn = document.getElementById('btnSend');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Enviando...';
        });
    </script>
}
