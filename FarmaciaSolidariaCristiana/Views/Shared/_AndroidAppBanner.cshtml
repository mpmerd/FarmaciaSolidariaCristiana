@* Banner para promover la descarga de la aplicación Android *@
<div id="androidAppBanner" class="android-app-banner mt-4 mb-4">
    <div class="container">
        <div class="card border-success shadow-sm">
            <div class="card-body p-3" style="background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);">
                <button type="button" class="btn-close btn-close-white float-end" aria-label="Cerrar" onclick="dismissAndroidBanner()"></button>
                <div class="d-flex align-items-center">
                    <div class="me-3">
                        <i class="bi bi-android2 text-white" style="font-size: 3rem;"></i>
                    </div>
                    <div class="flex-grow-1 text-white">
                        <h6 class="mb-1 fw-bold">¡Descarga nuestra App para Android!</h6>
                        <p class="mb-2 small">Accede más rápido y recibe notificaciones</p>
                        <a href="https://www.farmaciasolidaria.somee.com/android/" 
                           class="btn btn-light btn-sm shadow"
                           target="_blank">
                            <i class="bi bi-download"></i> Descargar APK
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .android-app-banner {
        animation: slideDown 0.5s ease-out;
    }
    
    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    @@keyframes slideUp {
        from {
            opacity: 1;
            transform: translateY(0);
        }
        to {
            opacity: 0;
            transform: translateY(-20px);
        }
    }
</style>

<script>
    // Mostrar el banner en TODOS los dispositivos si no ha sido cerrado
    (function() {
        const bannerDismissed = localStorage.getItem('androidBannerDismissed');
        
        if (bannerDismissed) {
            document.getElementById('androidAppBanner').style.display = 'none';
        }
    })();
    
    function dismissAndroidBanner() {
        localStorage.setItem('androidBannerDismissed', 'true');
        const banner = document.getElementById('androidAppBanner');
        banner.style.animation = 'slideUp 0.3s ease-out';
        setTimeout(() => {
            banner.style.display = 'none';
        }, 300);
    }
</script>
