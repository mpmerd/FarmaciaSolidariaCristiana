<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FarmaciaSolidariaCristiana.Maui.ViewModels"
             xmlns:services="clr-namespace:FarmaciaSolidariaCristiana.Maui.Services"
             x:Class="FarmaciaSolidariaCristiana.Maui.Views.UsuariosPage"
             x:DataType="viewmodels:UsuariosViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource BackgroundColor}">

    <Grid RowDefinitions="Auto,*">
        <!-- Header Section -->
        <StackLayout Grid.Row="0" Padding="15" Spacing="15">
                    
                    <!-- Header -->
                    <Frame BackgroundColor="{StaticResource Primary}" 
                           CornerRadius="15" 
                           Padding="20"
                           HasShadow="True">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackLayout Grid.Column="0">
                                <Label Text="👥 Gestión de Usuarios" 
                                       FontSize="22" 
                                       FontAttributes="Bold"
                                       TextColor="White"/>
                                <Label Text="Administrar usuarios del sistema" 
                                       FontSize="14" 
                                       TextColor="#B0D4FF"/>
                            </StackLayout>
                            <Button Grid.Column="1"
                                    Text="➕"
                                    FontSize="20"
                                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2a2a2a}"
                                    TextColor="{StaticResource Primary}"
                                    CornerRadius="25"
                                    WidthRequest="50"
                                    HeightRequest="50"
                                    Command="{Binding StartCreatingCommand}"
                                    IsVisible="{Binding IsEditing, Converter={StaticResource InverseBoolConverter}}"/>
                        </Grid>
                    </Frame>

                    <!-- Información de roles -->
                    <Frame BackgroundColor="#E3F2FD" CornerRadius="12" Padding="15" HasShadow="False">
                        <StackLayout Spacing="8">
                            <Label Text="ℹ️ Roles Disponibles:" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Dark}"/>
                            <Label Text="• Admin: Acceso completo al sistema" FontSize="13" TextColor="{StaticResource Gray600}"/>
                            <Label Text="• Farmacéutico: Gestiona medicamentos, entregas, turnos" FontSize="13" TextColor="{StaticResource Gray600}"/>
                            <Label Text="• Viewer: Solo visualiza información y reportes" FontSize="13" TextColor="{StaticResource Gray600}"/>
                            <Label Text="• Paciente: Solicita turnos y ve su información" FontSize="13" TextColor="{StaticResource Gray600}"/>
                        </StackLayout>
                    </Frame>

                    <!-- Formulario Crear/Editar Usuario -->
                    <Frame IsVisible="{Binding IsCreating}"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2a2a2a}" 
                           CornerRadius="15" 
                           Padding="20"
                           HasShadow="True">
                        <StackLayout Spacing="15">
                            <Label Text="➕ Crear Nuevo Usuario" 
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Dark}"/>

                            <StackLayout Spacing="5">
                                <Label Text="Nombre de Usuario *" FontSize="14" TextColor="{StaticResource Gray600}"/>
                                <Entry Text="{Binding EditUserName}" 
                                       Placeholder="Ej: JuanPerez"
                                       TextColor="{AppThemeBinding Light=#1a1a1a, Dark=#e0e0e0}"
                                       PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#bbbbbb}"
                                       BackgroundColor="{StaticResource Gray100}"/>
                            </StackLayout>

                            <StackLayout Spacing="5">
                                <Label Text="Email *" FontSize="14" TextColor="{StaticResource Gray600}"/>
                                <Entry Text="{Binding EditEmail}" 
                                       Placeholder="correo@ejemplo.com"
                                       Keyboard="Email"
                                       TextColor="{AppThemeBinding Light=#1a1a1a, Dark=#e0e0e0}"
                                       PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#bbbbbb}"
                                       BackgroundColor="{StaticResource Gray100}"/>
                            </StackLayout>

                            <StackLayout Spacing="5">
                                <Label Text="Contraseña *" FontSize="14" TextColor="{StaticResource Gray600}"/>
                                <Entry Text="{Binding EditPassword}" 
                                       Placeholder="Mínimo 6 caracteres"
                                       IsPassword="True"
                                       TextColor="{AppThemeBinding Light=#1a1a1a, Dark=#e0e0e0}"
                                       PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#bbbbbb}"
                                       BackgroundColor="{StaticResource Gray100}"/>
                            </StackLayout>

                            <StackLayout Spacing="5">
                                <Label Text="Rol *" FontSize="14" TextColor="{StaticResource Gray600}"/>
                                <Picker ItemsSource="{Binding RolesDisponibles}"
                                        SelectedItem="{Binding EditSelectedRole}"
                                        BackgroundColor="{StaticResource Gray100}"/>
                            </StackLayout>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Text="Cancelar"
                                        BackgroundColor="{StaticResource Gray400}"
                                        TextColor="White"
                                        CornerRadius="10"
                                        Command="{Binding CancelEditCommand}"/>
                                <Button Grid.Column="1"
                                        Text="Crear Usuario"
                                        BackgroundColor="{StaticResource Primary}"
                                        TextColor="White"
                                        CornerRadius="10"
                                        Command="{Binding SaveUserCommand}"/>
                            </Grid>
                        </StackLayout>
                    </Frame>

                    <!-- Formulario Editar Usuario -->
                    <Frame IsVisible="{Binding IsEditing}"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2a2a2a}" 
                           CornerRadius="15" 
                           Padding="20"
                           HasShadow="True">
                        <StackLayout Spacing="15">
                            <Label Text="✏️ Editar Usuario" 
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Dark}"/>

                            <StackLayout Spacing="5">
                                <Label Text="Nombre de Usuario *" FontSize="14" TextColor="{StaticResource Gray600}"/>
                                <Entry Text="{Binding EditUserName}" 
                                       TextColor="{AppThemeBinding Light=#1a1a1a, Dark=#e0e0e0}"
                                       PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#bbbbbb}"
                                       BackgroundColor="{StaticResource Gray100}"/>
                            </StackLayout>

                            <StackLayout Spacing="5">
                                <Label Text="Email *" FontSize="14" TextColor="{StaticResource Gray600}"/>
                                <Entry Text="{Binding EditEmail}" 
                                       Keyboard="Email"
                                       TextColor="{AppThemeBinding Light=#1a1a1a, Dark=#e0e0e0}"
                                       PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#bbbbbb}"
                                       BackgroundColor="{StaticResource Gray100}"/>
                            </StackLayout>

                            <StackLayout Spacing="5">
                                <Label Text="Nueva Contraseña (dejar vacío para no cambiar)" FontSize="14" TextColor="{StaticResource Gray600}"/>
                                <Entry Text="{Binding EditPassword}" 
                                       Placeholder="Solo si desea cambiarla"
                                       IsPassword="True"
                                       TextColor="{AppThemeBinding Light=#1a1a1a, Dark=#e0e0e0}"
                                       PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#bbbbbb}"
                                       BackgroundColor="{StaticResource Gray100}"/>
                            </StackLayout>

                            <StackLayout Spacing="5">
                                <Label Text="Rol *" FontSize="14" TextColor="{StaticResource Gray600}"/>
                                <Picker ItemsSource="{Binding RolesDisponibles}"
                                        SelectedItem="{Binding EditSelectedRole}"
                                        BackgroundColor="{StaticResource Gray100}"/>
                            </StackLayout>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Text="Cancelar"
                                        BackgroundColor="{StaticResource Gray400}"
                                        TextColor="White"
                                        CornerRadius="10"
                                        Command="{Binding CancelEditCommand}"/>
                                <Button Grid.Column="1"
                                        Text="Guardar Cambios"
                                        BackgroundColor="{StaticResource Primary}"
                                        TextColor="White"
                                        CornerRadius="10"
                                        Command="{Binding SaveUserCommand}"/>
                            </Grid>
                        </StackLayout>
                    </Frame>
        </StackLayout>

        <!-- Lista de Usuarios con RefreshView -->
        <RefreshView Grid.Row="1" 
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding LoadUsuariosCommand}">
            <CollectionView ItemsSource="{Binding Usuarios}"
                            EmptyView="No hay usuarios registrados"
                            SelectionMode="None">
                <CollectionView.Header>
                    <Label Text="📋 Usuarios del Sistema" 
                           FontSize="18" 
                           FontAttributes="Bold"
                           TextColor="{StaticResource Dark}"
                           Margin="15,10,15,5"/>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:UserDto">
                        <Grid Padding="15,5" ColumnDefinitions="50,*,Auto" RowDefinitions="Auto,Auto">
                            <!-- Avatar Circle-->
                            <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                    WidthRequest="50" HeightRequest="50"
                                    StrokeThickness="0"
                                    BackgroundColor="{StaticResource Gray100}"
                                    Margin="0,0,12,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="25"/>
                                </Border.StrokeShape>
                                <Label Text="👤" 
                                       FontSize="24" 
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center"/>
                            </Border>

                            <!-- Info -->
                            <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2">
                                <Label Text="{Binding UserName}" 
                                       FontSize="16" 
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#1a1a1a, Dark=#e0e0e0}"/>
                                <Label Text="{Binding Email}" 
                                       FontSize="13" 
                                       TextColor="{StaticResource Gray600}"/>
                            </VerticalStackLayout>

                            <!-- Rol Badge -->
                            <Border Grid.Row="0" Grid.Column="2"
                                    BackgroundColor="{Binding Role, Converter={StaticResource RoleToColorConverter}}"
                                    StrokeThickness="0"
                                    Padding="8,4"
                                    VerticalOptions="Start">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="{Binding Role}" 
                                       FontSize="11" 
                                       TextColor="White"
                                       FontAttributes="Bold"/>
                            </Border>

                            <!-- Acciones -->
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                                   Spacing="10"
                                                   Margin="0,10,0,0">
                                <Button Text="✏️ Editar"
                                        FontSize="12"
                                        HeightRequest="35"
                                        Padding="10,0"
                                        BackgroundColor="{StaticResource Primary}"
                                        TextColor="White"
                                        CornerRadius="8"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:UsuariosViewModel}}, Path=StartEditingCommand}"
                                        CommandParameter="{Binding .}"/>
                                <Button Text="🗑️ Eliminar"
                                        FontSize="12"
                                        HeightRequest="35"
                                        Padding="10,0"
                                        BackgroundColor="#dc3545"
                                        TextColor="White"
                                        CornerRadius="8"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:UsuariosViewModel}}, Path=DeleteUserCommand}"
                                        CommandParameter="{Binding .}"/>
                            </HorizontalStackLayout>

                            <!-- Separator line -->
                            <BoxView Grid.Row="1" Grid.ColumnSpan="3" 
                                     HeightRequest="1" 
                                     Color="{StaticResource Gray200}"
                                     VerticalOptions="End"
                                     Margin="0,10,0,0"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="2" 
              IsVisible="{Binding IsBusy}" 
              BackgroundColor="#80000000">
            <ActivityIndicator IsRunning="True" 
                               Color="White"
                               HeightRequest="50"
                               WidthRequest="50"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
        </Grid>
    </Grid>

</ContentPage>
