<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FarmaciaSolidariaCristiana.Maui.Views.PdfViewerPage"
             Title="PDF del Turno"
             Shell.NavBarIsVisible="True">
    
    <Grid BackgroundColor="#f5f5f5">
        <!-- PDF en WebView -->
        <WebView x:Name="PdfViewer"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill"
                 IsVisible="False"/>
        
        <!-- Loading -->
        <VerticalStackLayout x:Name="LoadingView"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             IsVisible="True">
            <ActivityIndicator IsRunning="True" 
                               Color="{StaticResource Primary}" 
                               HeightRequest="50" 
                               WidthRequest="50"/>
            <Label x:Name="LoadingLabel" 
                   Text="Preparando PDF..." 
                   TextColor="{StaticResource Gray600}" 
                   Margin="0,10,0,0"/>
        </VerticalStackLayout>
        
        <!-- Error -->
        <VerticalStackLayout x:Name="ErrorView"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Padding="30"
                             IsVisible="False">
            <Label Text="❌" FontSize="60" HorizontalTextAlignment="Center"/>
            <Label x:Name="ErrorLabel" 
                   Text="Error al cargar el PDF" 
                   TextColor="{StaticResource Gray600}" 
                   FontSize="18"
                   HorizontalTextAlignment="Center"
                   Margin="20,10"/>
            <Button Text="Cerrar" 
                    Clicked="OnCloseClicked"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="10"
                    WidthRequest="150"
                    Margin="0,20,0,0"/>
        </VerticalStackLayout>
        
        <!-- Toolbar de acciones -->
        <Frame x:Name="ToolbarFrame"
               BackgroundColor="{StaticResource Primary}"
               Padding="10"
               CornerRadius="25"
               HasShadow="True"
               VerticalOptions="End"
               HorizontalOptions="Center"
               Margin="20"
               IsVisible="False">
            <HorizontalStackLayout Spacing="20">
                <Button Text="📤" 
                        FontSize="24"
                        BackgroundColor="Transparent"
                        Clicked="OnShareClicked"
                        ToolTipProperties.Text="Compartir"/>
                <Button Text="📥" 
                        FontSize="24"
                        BackgroundColor="Transparent"
                        Clicked="OnOpenExternalClicked"
                        ToolTipProperties.Text="Abrir en otra app"/>
            </HorizontalStackLayout>
        </Frame>
    </Grid>
</ContentPage>
