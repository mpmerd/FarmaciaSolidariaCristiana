<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FarmaciaSolidariaCristiana.Maui.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="FarmaciaSolidariaCristiana.Maui.Views.RegisterPage"
             x:DataType="viewmodels:RegisterViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BackgroundColor}">

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="30" VerticalOptions="Center">
            
            <!-- Logo -->
            <Image Source="logo.png" 
                   HeightRequest="100" 
                   Aspect="AspectFit"
                   Margin="0,0,0,10"/>
            
            <!-- Título -->
            <Label Text="Crear Cuenta"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="{StaticResource Primary}"/>
            
            <Label Text="Complete los datos para registrarse"
                   FontSize="14"
                   HorizontalTextAlignment="Center"
                   TextColor="{StaticResource Gray500}"
                   Margin="0,0,0,10"/>
            
            <!-- Mensaje de registro deshabilitado -->
            <Frame BackgroundColor="{StaticResource Warning}"
                   Padding="15"
                   CornerRadius="10"
                   IsVisible="{Binding RegistrationEnabled, Converter={toolkit:InvertedBoolConverter}}">
                <Label Text="{Binding RegistrationMessage}"
                       TextColor="White"
                       HorizontalTextAlignment="Center"/>
            </Frame>
            
            <!-- Nombre de Usuario -->
            <Frame BorderColor="{StaticResource Gray200}" 
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#2a2a2a}"
                   Padding="10" 
                   CornerRadius="10"
                   HasShadow="False"
                   IsEnabled="{Binding RegistrationEnabled}">
                <Entry Placeholder="Nombre de usuario"
                       Text="{Binding UserName}"
                       TextColor="{AppThemeBinding Light=#1a1a1a, Dark=#e0e0e0}"
                       PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#bbbbbb}"
                       ReturnType="Next"/>
            </Frame>
            
            <!-- Email -->
            <Frame BorderColor="{StaticResource Gray200}" 
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#2a2a2a}"
                   Padding="10" 
                   CornerRadius="10"
                   HasShadow="False"
                   IsEnabled="{Binding RegistrationEnabled}">
                <Entry Placeholder="Correo electrónico"
                       Text="{Binding Email}"
                       TextColor="{AppThemeBinding Light=#1a1a1a, Dark=#e0e0e0}"
                       PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#bbbbbb}"
                       Keyboard="Email"
                       ReturnType="Next"/>
            </Frame>

            <!-- Botón Enviar Código de Verificación -->
            <Button Text="{Binding IsCooldownActive, Converter={StaticResource BoolToSendCodeTextConverter}}"
                    Command="{Binding SendVerificationCodeCommand}"
                    IsEnabled="{Binding IsCooldownActive, Converter={toolkit:InvertedBoolConverter}}"
                    IsVisible="{Binding RegistrationEnabled}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="44"
                    FontSize="14">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsSendingCode}" Value="True">
                        <Setter Property="Text" Value="Enviando código..."/>
                        <Setter Property="IsEnabled" Value="False"/>
                    </DataTrigger>
                    <DataTrigger TargetType="Button" Binding="{Binding IsCooldownActive}" Value="True">
                        <Setter Property="IsEnabled" Value="False"/>
                        <Setter Property="BackgroundColor" Value="{StaticResource Gray400}"/>
                    </DataTrigger>
                </Button.Triggers>
            </Button>

            <!-- Mensaje estado del código -->
            <Label Text="{Binding CodeStatusMessage}"
                   IsVisible="{Binding CodeStatusMessage, Converter={StaticResource StringToBoolConverter}}"
                   TextColor="{Binding IsCodeStatusError, Converter={StaticResource BoolToCodeStatusColorConverter}}"
                   HorizontalTextAlignment="Center"
                   FontSize="13"/>

            <!-- Código de Verificación -->
            <Frame BorderColor="{StaticResource Gray200}" 
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#2a2a2a}"
                   Padding="10" 
                   CornerRadius="10"
                   HasShadow="False"
                   IsVisible="{Binding IsCodeSent}"
                   IsEnabled="{Binding RegistrationEnabled}">
                <VerticalStackLayout Spacing="5">
                    <Entry Placeholder="Código de 6 dígitos"
                           Text="{Binding VerificationCode}"
                           TextColor="{AppThemeBinding Light=#1a1a1a, Dark=#e0e0e0}"
                           PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#bbbbbb}"
                           Keyboard="Numeric"
                           MaxLength="6"
                           HorizontalTextAlignment="Center"
                           FontSize="20"
                           ReturnType="Next"/>
                    <Label Text="Revisa tu correo electrónico. El código expira en 10 minutos."
                           FontSize="11"
                           TextColor="{StaticResource Gray500}"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Frame>
            
            <!-- Password -->
            <Frame BorderColor="{StaticResource Gray200}" 
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#2a2a2a}"
                   Padding="10" 
                   CornerRadius="10"
                   HasShadow="False"
                   IsEnabled="{Binding RegistrationEnabled}">
                <Grid ColumnDefinitions="*, Auto">
                    <Entry Placeholder="Contraseña"
                           Text="{Binding Password}"
                           TextColor="{AppThemeBinding Light=#1a1a1a, Dark=#e0e0e0}"
                           PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#bbbbbb}"
                           IsPassword="{Binding IsPasswordVisible, Converter={toolkit:InvertedBoolConverter}}"
                           ReturnType="Next"/>
                    <ImageButton Grid.Column="1"
                                 Source="{Binding IsPasswordVisible, Converter={StaticResource BoolToPasswordIconConverter}}"
                                 Command="{Binding TogglePasswordVisibilityCommand}"
                                 HeightRequest="24"
                                 WidthRequest="24"/>
                </Grid>
            </Frame>
            
            <!-- Confirm Password -->
            <Frame BorderColor="{StaticResource Gray200}" 
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#2a2a2a}"
                   Padding="10" 
                   CornerRadius="10"
                   HasShadow="False"
                   IsEnabled="{Binding RegistrationEnabled}">
                <Grid ColumnDefinitions="*, Auto">
                    <Entry Placeholder="Confirmar contraseña"
                           Text="{Binding ConfirmPassword}"
                           TextColor="{AppThemeBinding Light=#1a1a1a, Dark=#e0e0e0}"
                           PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#bbbbbb}"
                           IsPassword="{Binding IsConfirmPasswordVisible, Converter={toolkit:InvertedBoolConverter}}"
                           ReturnType="Done"/>
                    <ImageButton Grid.Column="1"
                                 Source="{Binding IsConfirmPasswordVisible, Converter={StaticResource BoolToPasswordIconConverter}}"
                                 Command="{Binding ToggleConfirmPasswordVisibilityCommand}"
                                 HeightRequest="24"
                                 WidthRequest="24"/>
                </Grid>
            </Frame>
            
            <!-- Error Message -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource Danger}"
                   IsVisible="{Binding HasError}"
                   HorizontalTextAlignment="Center"/>
            
            <!-- Register Button -->
            <Button Text="Registrarse"
                    Command="{Binding RegisterCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    IsVisible="{Binding RegistrationEnabled}"
                    BackgroundColor="{AppThemeBinding Light=#28a745, Dark=#1e7e34}"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="50"
                    FontAttributes="Bold"/>
            
            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}"
                               HeightRequest="40"/>
            
            <!-- Link para volver -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,10,0,0">
                <Label Text="¿Ya tiene cuenta?"
                       TextColor="{StaticResource Gray500}"/>
                <Label Text="Inicie sesión"
                       TextColor="{StaticResource Primary}"
                       FontAttributes="Bold"
                       TextDecorations="Underline">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
            
            <!-- Información -->
            <Frame BackgroundColor="{StaticResource Gray100}"
                   Padding="15"
                   CornerRadius="10"
                   Margin="0,20,0,0">
                <VerticalStackLayout Spacing="5">
                    <Label Text="ℹ️ Información"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray600}"/>
                    <Label Text="Al registrarse podrá solicitar turnos de medicamentos. Su cuenta será revisada por el personal de la farmacia."
                           FontSize="12"
                           TextColor="{StaticResource Gray500}"/>
                </VerticalStackLayout>
            </Frame>
            
            <!-- Footer -->
            <Label Text="© 2026 Farmacia Solidaria Cristiana"
                   FontSize="12"
                   TextColor="{StaticResource Gray400}"
                   HorizontalTextAlignment="Center"
                   Margin="0,20,0,0"/>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
