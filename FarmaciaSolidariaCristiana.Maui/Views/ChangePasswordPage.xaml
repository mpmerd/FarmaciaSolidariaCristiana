<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FarmaciaSolidariaCristiana.Maui.ViewModels"
             x:Class="FarmaciaSolidariaCristiana.Maui.Views.ChangePasswordPage"
             x:DataType="viewmodels:ChangePasswordViewModel"
             Title="Cambiar Contraseña"
             BackgroundColor="{StaticResource BackgroundColor}">

    <ScrollView>
        <StackLayout Padding="20" Spacing="20">
            <!-- Header -->
            <Frame BackgroundColor="{StaticResource Primary}" 
                   CornerRadius="20" 
                   Padding="30,20"
                   HasShadow="True"
                   Margin="0,0,0,10">
                <StackLayout Spacing="10" HorizontalOptions="Center">
                    <Label Text="🔐" 
                           FontSize="48" 
                           HorizontalOptions="Center"/>
                    <Label Text="Cambiar Contraseña" 
                           FontSize="20" 
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"/>
                    <Label Text="Actualiza tu contraseña de acceso" 
                           FontSize="14" 
                           TextColor="#B0D4FF"
                           HorizontalOptions="Center"/>
                </StackLayout>
            </Frame>

            <!-- Current Password -->
            <Frame BackgroundColor="White" CornerRadius="15" Padding="15" HasShadow="True">
                <StackLayout Spacing="8">
                    <Label Text="Contraseña Actual" 
                           FontSize="14" 
                           FontAttributes="Bold"
                           TextColor="{StaticResource Dark}"/>
                    
                    <Grid ColumnDefinitions="*,Auto">
                        <Entry Grid.Column="0"
                               Text="{Binding CurrentPassword}"
                               Placeholder="Ingresa tu contraseña actual"
                               IsPassword="{Binding IsCurrentPasswordHidden}"
                               FontSize="16"
                               TextColor="{StaticResource Dark}"/>
                        
                        <Button Grid.Column="1"
                                Text="{Binding CurrentPasswordIcon}"
                                Command="{Binding ToggleCurrentPasswordVisibilityCommand}"
                                WidthRequest="40"
                                HeightRequest="40"
                                BackgroundColor="Transparent"
                                FontSize="20"
                                VerticalOptions="Center"
                                Padding="0"/>
                    </Grid>
                </StackLayout>
            </Frame>

            <!-- New Password -->
            <Frame BackgroundColor="White" CornerRadius="15" Padding="15" HasShadow="True">
                <StackLayout Spacing="8">
                    <Label Text="Nueva Contraseña" 
                           FontSize="14" 
                           FontAttributes="Bold"
                           TextColor="{StaticResource Dark}"/>
                    
                    <Grid ColumnDefinitions="*,Auto">
                        <Entry Grid.Column="0"
                               Text="{Binding NewPassword}"
                               Placeholder="Ingresa tu nueva contraseña"
                               IsPassword="{Binding IsNewPasswordHidden}"
                               FontSize="16"
                               TextColor="{StaticResource Dark}"/>
                        
                        <Button Grid.Column="1"
                                Text="{Binding NewPasswordIcon}"
                                Command="{Binding ToggleNewPasswordVisibilityCommand}"
                                WidthRequest="40"
                                HeightRequest="40"
                                BackgroundColor="Transparent"
                                FontSize="20"
                                VerticalOptions="Center"
                                Padding="0"/>
                    </Grid>
                    
                    <Label Text="Mínimo 6 caracteres" 
                           FontSize="12" 
                           TextColor="{StaticResource Gray500}"/>
                </StackLayout>
            </Frame>

            <!-- Confirm Password -->
            <Frame BackgroundColor="White" CornerRadius="15" Padding="15" HasShadow="True">
                <StackLayout Spacing="8">
                    <Label Text="Confirmar Nueva Contraseña" 
                           FontSize="14" 
                           FontAttributes="Bold"
                           TextColor="{StaticResource Dark}"/>
                    
                    <Grid ColumnDefinitions="*,Auto">
                        <Entry Grid.Column="0"
                               Text="{Binding ConfirmPassword}"
                               Placeholder="Confirma tu nueva contraseña"
                               IsPassword="{Binding IsConfirmPasswordHidden}"
                               FontSize="16"
                               TextColor="{StaticResource Dark}"/>
                        
                        <Button Grid.Column="1"
                                Text="{Binding ConfirmPasswordIcon}"
                                Command="{Binding ToggleConfirmPasswordVisibilityCommand}"
                                WidthRequest="40"
                                HeightRequest="40"
                                BackgroundColor="Transparent"
                                FontSize="20"
                                VerticalOptions="Center"
                                Padding="0"/>
                    </Grid>
                </StackLayout>
            </Frame>

            <!-- Change Password Button -->
            <Button Text="Actualizar Contraseña"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="15"
                    HeightRequest="55"
                    FontSize="16"
                    FontAttributes="Bold"
                    Command="{Binding ChangePasswordCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    Margin="0,10,0,0"/>

            <!-- Loading -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}"
                               HeightRequest="40"/>
        </StackLayout>
    </ScrollView>
</ContentPage>
