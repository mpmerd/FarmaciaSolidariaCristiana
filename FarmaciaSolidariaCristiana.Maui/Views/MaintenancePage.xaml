<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FarmaciaSolidariaCristiana.Maui.Views.MaintenancePage"
             Title="Mantenimiento"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#f0f4f8, Dark=#1a1a2e}">

    <Grid VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand"
          Padding="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Icono -->
        <Label Grid.Row="1"
               Text="🔧"
               FontSize="72"
               HorizontalOptions="Center"
               Margin="0,0,0,20"/>

        <!-- Título -->
        <Label Grid.Row="2"
               Text="Sistema en Mantenimiento"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center"
               TextColor="{AppThemeBinding Light=#1a1a1a, Dark=#e0e0e0}"
               Margin="0,0,0,15"/>

        <!-- Razón del mantenimiento -->
        <Frame Grid.Row="3"
               BackgroundColor="{AppThemeBinding Light=#fff3cd, Dark=#3d3520}"
               BorderColor="{AppThemeBinding Light=#ffc107, Dark=#665a1e}"
               CornerRadius="12"
               Padding="20"
               Margin="0,0,0,20">
            <Label x:Name="LblReason"
                   Text="Estamos realizando mejoras en el sistema. Volveremos pronto."
                   FontSize="16"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=#664d03, Dark=#f5e6a0}"/>
        </Frame>

        <!-- Mensaje adicional -->
        <Label Grid.Row="4"
               Text="La aplicación no está disponible en este momento. Por favor, intente nuevamente más tarde."
               FontSize="14"
               HorizontalTextAlignment="Center"
               TextColor="{AppThemeBinding Light=#6c757d, Dark=#adb5bd}"
               Margin="0,0,0,30"/>

        <!-- Botón reintentar -->
        <Button Grid.Row="5"
                x:Name="BtnRetry"
                Text="Reintentar"
                BackgroundColor="#0d6efd"
                TextColor="White"
                FontSize="16"
                FontAttributes="Bold"
                CornerRadius="10"
                HeightRequest="50"
                HorizontalOptions="Center"
                WidthRequest="200"
                Clicked="OnRetryClicked"/>
    </Grid>

</ContentPage>
